# Gemini API Keys
# AI_API_KEY is used for the main chat completion (e.g. Gemini 2.5 Flash)
AI_API_KEY=your_gemini_chat_key_here

# GEMINI_API_KEY is used specifically for the Embedding model (gemini-embedding-001)
GEMINI_API_KEY=your_gemini_embedding_key_here

# Supabase Credentials
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...